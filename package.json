{
  "name": "odyssey-wiki",
  "type": "module",
  "version": "1.0.1",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "license": "MIT",
  "scripts": {
    "build:items": "node mc-build-parser.js",
    "dev": "npm run build:items && vite dev",
